{
  "name": "construlog",
  "version": "1.0.6",
  "description": "App desktop para gerar propostas em PDF",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "publish": "electron-vite build && electron-builder --publish always",
    "publish:win": "electron-vite build && electron-builder --win --publish always",
    "publish:mac": "electron-vite build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.construlog.app",
    "productName": "Construlog",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "diegofersan",
      "repo": "construlog",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "electron-updater": "^6.3.9",
    "googleapis": "^144.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
